# priority 0
snippet vimline vimline
	# vim: set ts=4 sts=0 sw=4 si fenc=utf-8 et:
	# vim: set fdm=marker fmr={{{,}}} fdl=0 foldcolumn=4:

snippet hdr file-header
	# Authors:     TS
	# Maintainers: TS
	# Copyright:   YYYY, HRDAG, GPL v2 or later
	# =========================================


snippet curpath full current path, relative to git root
	${1:project/path/to/file}
